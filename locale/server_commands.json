{
  "version": "2.0",
  "categories": {
    "player": {
      "commands": [
        {
          "id": "mining_speed",
          "command": "/c game.players[\"{player}\"].force.manual_mining_speed_modifier={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "100"
        },
        {
          "id": "crafting_speed",
          "command": "/c game.players[\"{player}\"].force.manual_crafting_speed_modifier={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "100"
        },
        {
          "id": "character_speed",
          "command": "/c game.players[\"{player}\"].character_running_speed_modifier={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "1"
        },
        {
          "id": "set_reach_distance",
          "command": "/c game.players[\"{player}\"].force.character_build_distance_bonus={value}; game.players[\"{player}\"].force.character_reach_distance_bonus={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "10"
        },
        {
          "id": "inventory_size",
          "command": "/c game.players[\"{player}\"].force.character_inventory_slots_bonus={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "80"
        },
        {
          "id": "research_speed",
          "command": "/c game.players[\"{player}\"].force.laboratory_speed_modifier={value}",
          "has_player": true,
          "has_value": true,
          "default_value": "1"
        },
        {
          "id": "toggle_cheat_mode",
          "command": "/c game.players[\"{player}\"].cheat_mode={value}",
          "has_player": true,
          "has_boolean": true,
          "default_value": "true"
        },
        {
          "id": "teleport_spawn",
          "command": "/c game.players[\"{player}\"].teleport({0,0})",
          "has_player": true
        },
        {
          "id": "teleport_all_spawn",
          "command": "/c for _, player in pairs(game.connected_players) do player.teleport({0, 0}) end"
        },
        {
          "id": "god_mode_on",
          "command": "/c game.players[\"{player}\"].character.destroy()",
          "has_player": true
        },
        {
          "id": "god_mode_off",
          "command": "/c game.players[\"{player}\"].create_character()",
          "has_player": true
        }
      ]
    },
    "game": {
      "commands": [
        {
          "id": "game_speed",
          "command": "/c game.speed={value}",
          "has_value": true,
          "default_value": "1"
        },
        {
          "id": "toggle_pollution",
          "command": "/c game.map_settings.pollution.enabled={value}",
          "has_boolean": true,
          "default_value": "false"
        },
        {
          "id": "add_pollution",
          "command": "/c local player=game.players[\"{player}\"] player.surface.pollute(player.position, {value})",
          "has_player": true,
          "has_value": true,
          "default_value": "1000000"
        },
        {
          "id": "remove_pollution",
          "command": "/c game.players[\"{player}\"].surface.clear_pollution()",
          "has_player": true,
          "requires_value": false
        },
        {
          "id": "toggle_always_day",
          "command": "/c game.players[\"{player}\"].surface.always_day={value}",
          "has_player": true,
          "has_boolean": true,
          "default_value": "true"
        }
      ]
    },
    "items": {
      "commands": [
        {
          "id": "give_item",
          "command": "/c game.players[\"{player}\"].insert{name=\"{item}\", count={count}, quality=\"{quality}\"}",
          "has_player": true,
          "has_item": true,
          "items": {
            "logistic-robot": 50,
            "construction-robot": 50,
            "roboport": 10,
            "active-provider-chest": 50,
            "buffer-chest": 50,
