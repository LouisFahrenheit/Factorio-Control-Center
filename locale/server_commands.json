          "id": "give_power_armor_mk2",
          "command": "/c local p=game.players[\"{player}\"] p.insert{name=\"power-armor-mk2\",count=1} local g=p.get_inventory(5)[1].grid g.put({name=\"fission-reactor-equipment\"}) g.put({name=\"fission-reactor-equipment\"}) g.put({name=\"fission-reactor-equipment\"}) g.put({name=\"exoskeleton-equipment\"}) g.put({name=\"exoskeleton-equipment\"}) g.put({name=\"exoskeleton-equipment\"}) g.put({name=\"exoskeleton-equipment\"}) g.put({name=\"energy-shield-mk2-equipment\"}) g.put({name=\"energy-shield-mk2-equipment\"}) g.put({name=\"personal-roboport-mk2-equipment\"}) g.put({name=\"night-vision-equipment\"}) g.put({name=\"battery-mk2-equipment\"}) g.put({name=\"battery-mk2-equipment\"}) p.insert{name=\"construction-robot\",count=25}",
          "has_player": true
        },
        {
          "id": "give_legendary_armor",
          "command": "/c local p=game.players[\"{player}\"] p.insert{name=\"power-armor-mk2\",count=1,quality=\"legendary\"} local g=p.get_inventory(5)[1].grid g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"fission-reactor-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"exoskeleton-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"energy-shield-mk2-equipment\",quality=\"legendary\"})g.put({name=\"personal-roboport-mk2-equipment\",quality=\"legendary\"})g.put({name=\"night-vision-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"})g.put({name=\"battery-mk2-equipment\",quality=\"legendary\"}) p.insert{name=\"construction-robot\",count=50,quality=\"legendary\"}",
          "has_player": true
        }
      ]
    },
    "enemies": {
      "commands": [
        {
          "id": "toggle_peaceful_mode",
          "command": "/c game.players[\"{player}\"].surface.peaceful_mode={value}",
          "has_player": true,
          "has_boolean": true,
          "default_value": "true"
        },
        {
          "id": "evolution_factor",
          "command": "/c game.forces[\"enemy\"].set_evolution_factor({value}, game.players[\"{player}\"].surface)",
          "has_player": true,
          "has_value": true,
          "default_value": "0.37"
        },
        {
          "id": "disable_evolution_time",
          "command": "/c game.map_settings.enemy_evolution.time_factor=0"
        },
        {
          "id": "disable_evolution_pollution",
          "command": "/c game.map_settings.enemy_evolution.pollution_factor=0"
        },
        {
          "id": "disable_expansion",
          "command": "/c game.map_settings.enemy_expansion.enabled=false"
        },
        {
          "id": "kill_nearby_enemies",
          "command": "/c local p=game.players[\"{player}\"] local cnt=0 for k,e in pairs(p.surface.find_entities_filtered({force=\"enemy\",radius={value},position=p.position})) do cnt=cnt+1 e.destroy() end game.print(cnt)",
          "has_player": true,
          "has_value": true,
          "default_value": "250"
        },
        {
          "id": "kill_all_enemies",
          "command": "/c game.forces[\"enemy\"].kill_all_units()"
        }
      ]
    },
    "map": {
      "commands": [
        {
          "id": "reveal_around",
          "command": "/c local player=game.players[\"{player}\"] local radius={value} player.force.chart(player.surface,{{player.position.x-radius,player.position.y-radius},{player.position.x+radius,player.position.y+radius}})",
          "has_player": true,
          "has_value": true,
          "default_value": "500"
        },
        {
          "id": "hide_map",
          "command": "/c local p=game.players[\"{player}\"] if p then for c in p.surface.get_chunks() do p.force.unchart_chunk({x=c.x,y=c.y},p.surface) end end",
          "has_player": true
        },
        {
          "id": "reveal_all",
          "command": "/c game.players[\"{player}\"].force.chart_all()",
          "has_player": true
        }
      ]
    }
  }
}
